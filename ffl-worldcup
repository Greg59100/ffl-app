  if(myLeagues.length===0){
    container.innerHTML=`<div class="empty-state"><div class="empty-icon">🌍</div><div class="empty-title">Pas encore de ligue</div><div class="empty-sub">Crée ta FFL World Cup et invite tes amis à pronostiquer la Coupe du Monde 2026 !</div></div>`;
  }else{
    container.innerHTML=`<div class="sec">Mes ligues <span>${myLeagues.length}</span></div>`+myLeagues.map(renderLeagueCard).join('');
  }
}

function renderLeagueCard(l){
  const me=l.players.find(p=>p.isMe);
  const myScore=calcWCScore(me?.prono);
  const allScores=l.players.map(p=>({name:p.name,score:calcWCScore(p.prono)})).sort((a,b)=>b.score-a.score);
  const myRank=allScores.findIndex(p=>p.name===(me?.name||''))+1||1;
  const colors=['#1a1000','#001a0a','#00001a','#1a001a'];
  const avs=l.players.slice(0,5).map((p,i)=>`<div class="av" style="background:${colors[i%colors.length]};color:#aaa">${initials(p.name)}</div>`).join('');
  return `<div class="lc" onclick="openLeague('${l.id}')">
    <div class="lc-head"><div><div class="lc-name">${l.name}</div><div class="lc-sub">WC 2026 · ${l.players.length} joueur${l.players.length>1?'s':''}</div></div><div class="rank-badge">${myRank}<small>E</small></div></div>
    <div class="lc-stats"><div class="lc-stat"><div class="lc-val">${myScore.toLocaleString('fr')}</div><div class="lc-lbl">Mes pts</div></div><div class="lc-stat"><div class="lc-val">${l.players.length}</div><div class="lc-lbl">Joueurs</div></div><div class="lc-stat"><div class="lc-val" style="font-size:14px;color:var(--gray)">${l.code}</div><div class="lc-lbl">Code</div></div></div>
    <div class="lc-players">${avs}</div>
  </div>`;
}

function initials(name){return(name||'?').split(' ').map(w=>w[0]).join('').toUpperCase().slice(0,2);}

function renderGroups(){
