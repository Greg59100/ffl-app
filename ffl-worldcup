</div>

<div class="screen" id="s-league">
  <div class="topbar">
    <div class="topbar-row">
      <div class="icon-btn" onclick="nav('s-home')">←</div>
      <div class="topbar-title" id="league-title">Ma Ligue</div>
    </div>
    <div class="icon-btn" onclick="openShareModal()">📤</div>
  </div>
  <div class="scroll">
    <div class="pills">
      <div class="pill active" onclick="leaguePill(this,'rank')">Classement</div>
      <div class="pill" onclick="leaguePill(this,'pronos')">Pronos</div>
      <div class="pill" onclick="leaguePill(this,'details')">Détails</div>
