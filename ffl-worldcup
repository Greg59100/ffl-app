    <div id="league-rank-panel"></div>
    <div id="league-pronos-panel" style="display:none"></div>
    <div id="league-details-panel" style="display:none"></div>
  </div>
</div>

<div class="screen" id="s-prono">
  <div class="topbar">
    <div class="topbar-row">
      <div class="icon-btn" onclick="nav('s-home')">←</div>
      <div class="topbar-title">Mon Pronostic</div>
    </div>
    <div class="chip gold" id="prono-status-chip">Non soumis</div>
  </div>
  <div class="scroll" id="prono-scroll"></div>
</div>

<div class="screen" id="s-groups">
  <div class="topbar">
    <div class="topbar-row">
      <div class="icon-btn" onclick="nav('s-home')">←</div>
      <div class="topbar-title">Groupes 2026</div>
    </div>
  </div>
  <div class="scroll" id="groups-scroll"></div>
</div>

<div class="screen" id="s-profil">
  <div class="topbar">
    <div class="topbar-row">
      <div class="icon-btn" onclick="nav('s-home')">←</div>
      <div class="topbar-title">Mon Profil</div>
    </div>
  </div>
  <div class="scroll" id="profil-scroll"></div>
</div>

<div class="screen" id="s-create">
  <div class="topbar">
    <div class="topbar-row">
      <div class="icon-btn" onclick="nav('s-home')">←</div>
      <div class="topbar-title">Créer une ligue</div>
    </div>
  </div>
