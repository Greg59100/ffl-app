  <div class="topbar">
    <div style="font-weight:900;font-size:13px;text-transform:uppercase;letter-spacing:.5px;line-height:1.2">FFL <span style="color:var(--gold)">WORLD CUP</span> 2026<br><span style="font-size:14px;letter-spacing:3px">🇺🇸🇨🇦🇲🇽</span></div>
    <div class="topbar-row">
      <div class="icon-btn" onclick="nav('s-profil')"><svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg></div>
    </div>
  </div>
  <div class="scroll">
