
<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1, user-scalable=no">
<title>FFL — World Cup 2026</title>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,600;0,700;0,800;0,900;1,700;1,800;1,900&display=swap" rel="stylesheet">
<style>
:root{--black:#080808;--dark:#111;--card:#181818;--card2:#212121;--card3:#2a2a2a;--gold:#f5c842;--gold-dark:#c49a00;--green:#00d45a;--red:#ff4444;--white:#f2f2f2;--gray:#777;--gray2:#444;--border:rgba(255,255,255,.07);--border2:rgba(255,255,255,.12);--font-h:'Barlow Condensed',sans-serif;--radius:14px;--radius-sm:10px}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html,body{touch-action:manipulation;height:100%;overflow:hidden}
body{background:var(--black);color:var(--white);font-family:var(--font-h);font-size:15px;font-weight:500}
#app{max-width:430px;margin:0 auto;height:100vh;display:flex;flex-direction:column;position:relative;overflow:hidden}
.screen{display:none;flex-direction:column;flex:1;overflow:hidden}
.screen.active{display:flex}
.scroll{flex:1;overflow-y:auto;-webkit-overflow-scrolling:touch;padding-bottom:100px}
.scroll::-webkit-scrollbar{display:none}
.topbar{display:flex;align-items:center;justify-content:space-between;padding:14px 18px 10px;flex-shrink:0;background:linear-gradient(to bottom,var(--black) 70%,transparent)}
.icon-btn{width:36px;height:36px;border-radius:9px;background:var(--card);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;cursor:pointer;flex-shrink:0;font-size:16px}
.topbar-row{display:flex;align-items:center;gap:10px}
.topbar-title{font-weight:800;font-size:20px;text-transform:uppercase;letter-spacing:.5px}
.bottom-nav{display:none;background:rgba(10,10,10,.97);backdrop-filter:blur(20px);border-top:1px solid var(--border);padding:8px 0 max(env(safe-area-inset-bottom),12px);flex-shrink:0;position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:100%;max-width:430px;z-index:100}
.bottom-nav.visible{display:flex}
.nav-btn{flex:1;display:flex;flex-direction:column;align-items:center;gap:3px;cursor:pointer;padding:2px 0;opacity:.4;transition:opacity .2s}
.nav-btn.active{opacity:1}
.nav-btn .ni{display:flex;align-items:center;justify-content:center;color:var(--gray2)}.nav-btn .ni svg{stroke:currentColor}.nav-btn.active .ni{color:var(--gold)}
.nav-btn .nl{font-weight:700;font-size:10px;letter-spacing:.5px;text-transform:uppercase}
.nav-btn.active .nl{color:var(--gold)}
.btn{font-weight:800;font-size:15px;text-transform:uppercase;letter-spacing:.8px;padding:13px 18px;border-radius:var(--radius-sm);border:none;cursor:pointer;transition:all .15s;width:100%}
.btn-gold{background:var(--gold);color:var(--black)}
.btn-outline{background:transparent;color:var(--white);border:1px solid var(--border2)}
.btn-row{display:flex;gap:10px;padding:0 18px 14px}
.input-wrap{margin-bottom:12px}
.input-lbl{font-size:10px;color:var(--gray);text-transform:uppercase;letter-spacing:1px;margin-bottom:5px}
.input{width:100%;background:var(--card2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:11px 14px;color:var(--white);font-family:var(--font-h);font-size:15px;outline:none;transition:border-color .2s}
.input:focus{border-color:var(--gold)}
.input::placeholder{color:var(--gray)}
textarea.input{resize:none;height:80px}
#toast{position:fixed;bottom:90px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--card3);border:1px solid var(--border2);border-radius:30px;padding:10px 20px;font-size:13px;font-weight:600;opacity:0;transition:all .3s;pointer-events:none;z-index:9999;white-space:nowrap}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0)}
#s-auth{position:fixed;inset:0;z-index:1000;background:var(--black);display:none;flex-direction:column;align-items:center;justify-content:center;padding:30px 24px;overflow-y:auto}
#s-auth.visible{display:flex}
.auth-logo{font-weight:900;font-size:30px;text-transform:uppercase;letter-spacing:2px;text-align:center;line-height:1.1;margin-bottom:4px}
.auth-logo em{color:var(--gold);font-style:normal}
.auth-sub{font-size:11px;color:var(--gray);letter-spacing:2px;text-transform:uppercase;margin-bottom:28px;text-align:center}
.auth-box{width:100%;background:var(--card);border:1px solid var(--border);border-radius:var(--radius);padding:20px}
.auth-tabs{display:flex;gap:0;margin-bottom:20px;background:var(--card2);border-radius:8px;padding:3px}
.auth-tab{flex:1;padding:8px;text-align:center;font-weight:700;font-size:13px;text-transform:uppercase;border-radius:6px;cursor:pointer;color:var(--gray);transition:all .2s}
.auth-tab.active{background:var(--gold);color:var(--black)}
.auth-error{background:rgba(255,68,68,.1);border:1px solid rgba(255,68,68,.3);border-radius:8px;padding:10px 14px;font-size:12px;color:var(--red);margin-bottom:12px;display:none}
.auth-error.show{display:block}
.wc-hero{margin:0 18px 18px;border-radius:var(--radius);background:linear-gradient(135deg,#1a0a00,#050505);border:1px solid rgba(245,200,66,.25);padding:20px;text-align:center;position:relative;overflow:hidden}
.wc-hero::after{content:'🏆';position:absolute;top:-15px;right:-10px;font-size:90px;opacity:.06;pointer-events:none}
.wc-hero-title{font-weight:900;font-size:34px;text-transform:uppercase;letter-spacing:2px;line-height:1}
.wc-hero-title em{color:var(--gold);font-style:normal}
.wc-hero-sub{font-size:11px;color:var(--gray);letter-spacing:3px;margin-top:4px;text-transform:uppercase}
.wc-hero-date{font-size:13px;color:var(--gold);margin-top:10px;font-weight:700}
.countdown{display:flex;gap:16px;justify-content:center;margin-top:12px}
.cd-item{text-align:center}
.cd-val{font-weight:900;font-size:30px;color:var(--white);line-height:1}
.cd-lbl{font-size:9px;color:var(--gray);text-transform:uppercase;letter-spacing:1px}
.lc{margin:0 18px 14px;border-radius:var(--radius);border:1px solid var(--border);background:var(--card);cursor:pointer;transition:transform .2s,border-color .2s;overflow:hidden}
.lc:hover{transform:translateY(-2px);border-color:rgba(245,200,66,.3)}
.lc-head{padding:14px 16px;background:linear-gradient(135deg,#141414,#1c1c1c);border-bottom:1px solid var(--border);display:flex;align-items:flex-start;justify-content:space-between}
.lc-name{font-weight:800;font-size:21px;text-transform:uppercase;line-height:1.1}
.lc-sub{font-size:11px;color:var(--gray);margin-top:3px}
.rank-badge{background:var(--gold);color:var(--black);font-weight:900;font-size:26px;width:48px;height:48px;border-radius:9px;display:flex;flex-direction:column;align-items:center;justify-content:center;line-height:1;flex-shrink:0}
.rank-badge small{font-size:8px;font-weight:800}
.lc-stats{display:flex;border-bottom:1px solid var(--border)}
.lc-stat{flex:1;text-align:center;padding:10px 0;border-right:1px solid var(--border)}
.lc-stat:last-child{border-right:none}
.lc-val{font-weight:800;font-size:22px;line-height:1;color:var(--gold)}
.lc-lbl{font-size:9px;color:var(--gray);text-transform:uppercase;letter-spacing:.5px;margin-top:2px}
.lc-players{padding:10px 16px;display:flex;align-items:center;gap:4px}
.av{width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:11px;border:2px solid var(--card);margin-left:-6px;flex-shrink:0}
.av:first-child{margin-left:0}
.sec{font-weight:800;font-size:17px;text-transform:uppercase;letter-spacing:.5px;padding:0 18px;margin-bottom:8px;margin-top:4px}
.sec span{color:var(--gray);font-size:13px;font-weight:600;text-transform:none;margin-left:6px}
.group-card{margin:0 18px 10px;background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);overflow:hidden}
.group-header{background:var(--card2);padding:8px 14px;font-weight:800;font-size:13px;text-transform:uppercase;letter-spacing:1px;color:var(--gold);border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center}
.team-row{display:flex;align-items:center;gap:10px;padding:9px 14px;border-bottom:1px solid var(--border);cursor:pointer;transition:background .15s}
.team-row:last-child{border-bottom:none}
.team-row.selected{background:rgba(245,200,66,.08);border-left:3px solid var(--gold)}
.team-flag{font-size:22px;flex-shrink:0;width:28px;text-align:center}
.team-name{flex:1;font-weight:600;font-size:14px}
.team-check{width:22px;height:22px;border-radius:50%;border:2px solid var(--border2);display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .2s;font-size:11px}
.team-check.checked{background:var(--gold);border-color:var(--gold);color:var(--black);font-weight:800}
.bracket-slots{display:grid;grid-template-columns:1fr 1fr;gap:8px;padding:0 18px 14px}
.bracket-slot{background:var(--card2);border:1px solid var(--border);border-radius:8px;padding:10px 12px;cursor:pointer;transition:all .2s;min-height:48px;display:flex;align-items:center;gap:8px}
.bracket-slot.filled{border-color:rgba(245,200,66,.4);background:rgba(245,200,66,.06)}
.slot-flag{font-size:18px;flex-shrink:0}
.slot-name{font-size:12px;font-weight:600;flex:1;line-height:1.2}
.slot-empty{font-size:11px;color:var(--gray)}
.slot-remove{font-size:14px;color:var(--gray);cursor:pointer;padding:2px}
.rank-tbl{margin:0 18px 16px;border-radius:var(--radius);border:1px solid var(--border);background:var(--card);overflow:hidden}
.rank-tbl-head{display:grid;grid-template-columns:32px 1fr 70px;padding:9px 14px;background:var(--card2);font-size:9px;color:var(--gray);text-transform:uppercase;letter-spacing:1px;border-bottom:1px solid var(--border)}
.rank-row{display:grid;grid-template-columns:32px 1fr 70px;padding:11px 14px;align-items:center;border-bottom:1px solid var(--border);gap:4px}
.rank-row:last-child{border-bottom:none}
.rank-row.me{background:rgba(245,200,66,.05);border-left:3px solid var(--gold)}
.rpos{font-weight:900;font-size:19px;color:var(--gray2)}
.rpos.p1{color:var(--gold)}.rpos.p2{color:#c0c0c0}.rpos.p3{color:#cd7f32}
.rname{font-weight:600;font-size:13px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.rname.me{color:var(--gold)}
.rsub{font-size:10px;color:var(--gray)}
.rscore{font-weight:800;font-size:19px;text-align:right;color:var(--gold)}
.pills{display:flex;gap:7px;padding:0 18px;margin-bottom:14px;overflow-x:auto;scrollbar-width:none}
.pills::-webkit-scrollbar{display:none}
.pill{padding:6px 14px;border-radius:30px;font-weight:700;font-size:13px;text-transform:uppercase;letter-spacing:.5px;white-space:nowrap;background:var(--card);border:1px solid var(--border);cursor:pointer;transition:all .2s;color:var(--gray)}
.pill.active{background:var(--gold);color:var(--black);border-color:var(--gold)}
.invite-box{background:linear-gradient(135deg,#1a1000,#0a0800);border:1px solid rgba(245,200,66,.25);border-radius:var(--radius);padding:16px;margin:0 18px 14px;text-align:center}
.invite-code{font-weight:900;font-size:42px;letter-spacing:6px;color:var(--gold);margin:8px 0}
.empty-state{text-align:center;padding:40px 30px}
.empty-icon{font-size:48px;margin-bottom:12px}
.empty-title{font-weight:800;font-size:22px;text-transform:uppercase;margin-bottom:8px}
.empty-sub{font-size:13px;color:var(--gray);line-height:1.5;margin-bottom:20px}
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.75);backdrop-filter:blur(4px);z-index:500;align-items:flex-end;justify-content:center}
.modal-bg.open{display:flex}
.modal{width:100%;max-width:430px;background:var(--dark);border-radius:20px 20px 0 0;border:1px solid var(--border);padding:18px 18px max(env(safe-area-inset-bottom),30px);animation:slideUp .3s ease;max-height:85vh;overflow-y:auto}
@keyframes slideUp{from{transform:translateY(100%)}to{transform:translateY(0)}}
.modal-handle{width:36px;height:4px;background:var(--gray2);border-radius:2px;margin:0 auto 16px}
.modal-title{font-weight:900;font-size:22px;text-transform:uppercase;margin-bottom:14px}
.chip{display:inline-flex;align-items:center;gap:5px;background:var(--card2);border:1px solid var(--border);border-radius:30px;padding:4px 10px;font-size:11px;font-weight:600}
.chip.gold{background:rgba(245,200,66,.12);border-color:rgba(245,200,66,.3);color:var(--gold)}
.chip.green{background:rgba(0,212,90,.12);border-color:rgba(0,212,90,.3);color:var(--green)}
#splash{position:fixed;inset:0;z-index:9999;background:var(--black);display:flex;flex-direction:column;align-items:center;justify-content:center;animation:splashFade .5s ease 2.2s forwards}
@keyframes splashFade{to{opacity:0;pointer-events:none;visibility:hidden}}
.splash-badge{font-size:60px;margin-bottom:12px;animation:fadeUp .4s ease .1s both}
.splash-title{font-weight:900;font-size:30px;text-transform:uppercase;letter-spacing:2px;text-align:center;line-height:1.1;animation:logoPop .6s cubic-bezier(.22,1,.36,1) .3s both}
.splash-title em{color:var(--gold);font-style:normal}
@keyframes logoPop{from{opacity:0;transform:scale(.85)}to{opacity:1;transform:scale(1)}}
.splash-sub{font-size:11px;color:var(--gray);letter-spacing:3px;text-transform:uppercase;margin-top:8px;animation:fadeUp .4s ease .8s both}
@keyframes fadeUp{from{opacity:0;transform:translateY(6px)}to{opacity:1;transform:translateY(0)}}
.splash-loader{width:40px;height:3px;background:var(--card2);border-radius:2px;margin-top:24px;overflow:hidden;animation:fadeUp .3s ease 1.1s both}
.splash-loader-fill{height:100%;background:var(--gold);border-radius:2px;animation:loadBar .7s ease 1.2s both}
@keyframes loadBar{from{width:0}to{width:100%}}
</style>
</head>
<body>

<div id="splash">
  <div class="splash-title">FFL <em>WORLD</em><br>CUP 2026</div>
  <div style="font-size:22px;letter-spacing:8px;margin-top:8px;animation:fadeUp .4s ease .7s both">🇺🇸🇨🇦🇲🇽</div>
  <div class="splash-sub" style="margin-top:6px">La ligue entre amis</div>
  <div class="splash-loader"><div class="splash-loader-fill"></div></div>
</div>

<div id="toast"></div>

<div id="s-auth">
  <div class="auth-logo">FFL <em>WORLD</em><br>CUP 2026</div>
  <div style="font-size:20px;letter-spacing:6px;margin-top:4px;margin-bottom:2px">🇺🇸🇨🇦🇲🇽</div>
