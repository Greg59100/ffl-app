      <div style="color:var(--gray)">Quart de finale</div><div style="color:var(--white);text-align:right;font-weight:700">${POINTS.quarterfinalist} pts</div>
      <div style="color:var(--gray)">Demi-finale</div><div style="color:var(--white);text-align:right;font-weight:700">${POINTS.semifinalist} pts</div>
