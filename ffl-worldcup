function renderCountdown(){
  const target=new Date('2026-06-11T19:00:00Z'),now=new Date(),diff=target-now;
  if(diff<=0){document.getElementById('countdown').innerHTML='<div style="color:var(--gold);font-weight:800">🔴 Le tournoi est en cours !</div>';return;}
  const days=Math.floor(diff/86400000),hours=Math.floor((diff%86400000)/3600000),mins=Math.floor((diff%3600000)/60000);
  document.getElementById('countdown').innerHTML=`<div class="cd-item"><div class="cd-val">${days}</div><div class="cd-lbl">Jours</div></div><div class="cd-item"><div class="cd-val">${hours}</div><div class="cd-lbl">Heures</div></div><div class="cd-item"><div class="cd-val">${mins}</div><div class="cd-lbl">Min</div></div>`;
}

function renderHome(){
  renderCountdown();
