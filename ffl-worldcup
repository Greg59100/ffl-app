      html+=`<div class="team-row${isSel?' selected':''}" onclick="toggleGroupQual('${letter}','${team.id}')"><div class="team-flag">${team.flag}</div><div class="team-name">${team.name}</div><div class="team-check${isSel?' checked':''}">${isSel?'✓':''}</div></div>`;
    });
    html+='</div>';
  });

  // QF
  html+=`<div class="sec" style="margin-top:8px">Quarts de finale <span>8 équipes</span></div>`;
  html+=renderBracketSlots('quarterfinalists',8,'Sélectionner');

  // SF
  html+=`<div class="sec">Demi-finales <span>4 équipes</span></div>`;
  html+=renderBracketSlots('semifinalists',4,'Sélectionner');

  // Finale
  html+=`<div class="sec">Finale <span>2 équipes</span></div>`;
  html+=renderBracketSlots('finalists',2,'Sélectionner');

  // Vainqueur
  html+=`<div class="sec">🏆 Vainqueur</div>`;
  const winnerTeam=myProno.winner?ALL_TEAMS.find(t=>t.id===myProno.winner):null;
  html+=`<div style="padding:0 18px 16px"><div class="bracket-slot${winnerTeam?' filled':''}" onclick="openPicker('winner',0)" style="max-width:220px">
    ${winnerTeam?`<div class="slot-flag">${winnerTeam.flag}</div><div class="slot-name">${winnerTeam.name}</div><div class="slot-remove" onclick="event.stopPropagation();clearSlot('winner')">✕</div>`:`<div class="slot-empty">🏆 Choisir le vainqueur</div>`}
  </div></div>`;

  // Buteur
  html+=`<div style="margin:0 18px 16px;background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px">
    <div style="font-weight:800;font-size:15px;text-transform:uppercase;letter-spacing:.5px;color:var(--gold);margin-bottom:4px">⚽ Meilleur buteur</div>
    <div style="font-size:12px;color:var(--gray);margin-bottom:10px">Prénom et nom du joueur que tu penses être le meilleur buteur.</div>
    <input class="input" id="scorer-input" placeholder="Ex : Kylian Mbappé" value="${myProno.top_scorer||''}">
  </div>`;

  html+=`<div class="btn-row"><button class="btn btn-gold" onclick="saveProno()">💾 Sauvegarder mon pronostic</button></div><div style="height:10px"></div>`;
  document.getElementById('prono-scroll').innerHTML=html;
}

function renderBracketSlots(key,count,placeholder){
  const selected=myProno[key]||[];
  let html=`<div class="bracket-slots">`;
  for(let i=0;i<count;i++){
    const teamId=selected[i];
    const team=teamId?ALL_TEAMS.find(t=>t.id===teamId):null;
    html+=`<div class="bracket-slot${team?' filled':''}" onclick="openPicker('${key}',${i})">
      ${team?`<div class="slot-flag">${team.flag}</div><div class="slot-name">${team.name}</div><div class="slot-remove" onclick="event.stopPropagation();removeFromSlot('${key}',${i})">✕</div>`:`<div class="slot-empty">${placeholder}</div>`}
    </div>`;
  }
  html+=`</div>`;
  return html;
}

function toggleGroupQual(group,teamId){
  if(!myProno.group_qualifiers)myProno.group_qualifiers={};
  const current=myProno.group_qualifiers[group]||[];
  if(current.includes(teamId)){myProno.group_qualifiers[group]=current.filter(id=>id!==teamId);}
  else{if(current.length>=2){toast('⚠️ Maximum 2 équipes par groupe !');return;}myProno.group_qualifiers[group]=[...current,teamId];}
  renderProno();
}

function openPicker(key,index){
  pickerCallback=(teamId)=>{
    if(key==='winner'){myProno.winner=teamId;}
    else{if(!myProno[key])myProno[key]=[];myProno[key]=myProno[key].filter((_,i)=>i!==index);myProno[key].splice(index,0,teamId);}
    closeModal('modal-picker');renderProno();
  };
  document.getElementById('picker-title').textContent=key==='winner'?'🏆 Choisir le vainqueur':'Choisir une équipe';
  const already=key==='winner'?[myProno.winner]:(myProno[key]||[]);
  let html='';
  Object.entries(WC_GROUPS).forEach(([letter,group])=>{
    html+=`<div style="font-size:10px;color:var(--gold);text-transform:uppercase;letter-spacing:1px;padding:8px 4px 4px">Groupe ${letter}</div>`;
    group.teams.forEach(team=>{
      const isSel=already.includes(team.id);
      html+=`<div class="team-row${isSel?' selected':''}" onclick="${isSel?'':("pickerCallback('"+team.id+"')")}"><div class="team-flag">${team.flag}</div><div class="team-name">${team.name}</div>${isSel?'<div style="color:var(--gold);font-size:11px">✓</div>':''}</div>`;
    });
  });
  document.getElementById('picker-teams').innerHTML=html;
  document.getElementById('modal-picker').classList.add('open');
}

function removeFromSlot(key,index){if(!myProno[key])return;myProno[key].splice(index,1);renderProno();}
function clearSlot(key){myProno[key]=key==='winner'?'':[];renderProno();}

async function saveProno(){
  myProno.top_scorer=document.getElementById('scorer-input')?.value?.trim()||'';
  localStorage.setItem('ffl_wc_prono_'+currentUser.id,JSON.stringify(myProno));
  try{
    const saves=myLeagues.map(league=>dbUpsert('wc_pronostics',{league_id:league.id,user_id:currentUser.id,group_qualifiers:myProno.group_qualifiers||{},quarterfinalists:myProno.quarterfinalists||[],semifinalists:myProno.semifinalists||[],finalists:myProno.finalists||[],winner:myProno.winner||'',top_scorer:myProno.top_scorer||'',updated_at:new Date().toISOString()},'league_id,user_id'));
    await Promise.all(saves);
    toast('✅ Pronostic sauvegardé !');
    await loadMyData();
    const chip=document.getElementById('prono-status-chip');
    if(chip){chip.textContent='✅ Soumis';chip.className='chip green';}
  }catch(e){toast('❌ Erreur : '+e.message);}
}

function openLeague(id){
  currentLeagueId=id;
  const league=myLeagues.find(l=>l.id===id);
  if(!league)return;
  document.getElementById('league-title').textContent=league.name;
  document.querySelectorAll('#s-league .pill').forEach((p,i)=>p.classList.toggle('active',i===0));
  ['rank','pronos','details'].forEach(p=>{const el=document.getElementById('league-'+p+'-panel');if(el)el.style.display=p==='rank'?'':'none';});
  nav('s-league');
}

function leaguePill(el,panel){
  document.querySelectorAll('#s-league .pill').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  ['rank','pronos','details'].forEach(p=>{const el=document.getElementById('league-'+p+'-panel');if(el)el.style.display=p===panel?'':'none';});
}

function renderLeague(){
  const league=myLeagues.find(l=>l.id===currentLeagueId);
  if(!league)return;
  const ranked=league.players.map(p=>({...p,score:calcWCScore(p.prono)})).sort((a,b)=>b.score-a.score);

  let rankHtml=`<div class="rank-tbl"><div class="rank-tbl-head"><div>#</div><div>Joueur</div><div style="text-align:right">Pts</div></div>`;
  ranked.forEach((p,i)=>{
    const pc=i===0?'p1':i===1?'p2':i===2?'p3':'';
    rankHtml+=`<div class="rank-row${p.isMe?' me':''}"><div class="rpos ${pc}">${i+1}</div><div><div class="rname${p.isMe?' me':''}">${p.name}${p.isMe?' (moi)':''}</div><div class="rsub">${p.prono?'Prono soumis ✓':'Pas encore de prono'}</div></div><div class="rscore">${p.score.toLocaleString('fr')}</div></div>`;
  });
  rankHtml+='</div>';
  if(league.stake)rankHtml+=`<div style="margin:0 18px 16px;background:linear-gradient(135deg,#1f1700,#150f00);border:1px solid rgba(245,200,66,.18);border-radius:10px;padding:14px"><div style="font-size:10px;color:var(--gold);text-transform:uppercase;letter-spacing:1px">🏆 Enjeu</div><div style="font-weight:700;margin-top:4px">${league.stake}</div></div>`;
  rankHtml+=`<div class="btn-row"><button class="btn btn-outline" onclick="openShareModal()">📤 Inviter des amis</button></div>`;
  document.getElementById('league-rank-panel').innerHTML=rankHtml;

  let pronosHtml='';
  league.players.forEach(p=>{
    const prono=p.prono;
    if(!prono){pronosHtml+=`<div style="padding:12px 18px"><div style="font-weight:600">${p.name}</div><div style="font-size:12px;color:var(--gray);margin-top:4px">Pronostic pas encore soumis</div></div>`;return;}
    const winner=prono.winner?ALL_TEAMS.find(t=>t.id===prono.winner):null;
    pronosHtml+=`<div style="margin:0 18px 8px;background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);padding:12px 14px">
      <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:6px">
        <div style="font-weight:600;font-size:14px">${p.name}${p.isMe?' (moi)':''}</div>
        <div style="font-size:12px;color:var(--gray)">${calcWCScore(prono).toLocaleString('fr')} pts</div>
      </div>
      <div style="font-size:12px;color:var(--gray)">🏆 Vainqueur : <b style="color:var(--white)">${winner?winner.flag+' '+winner.name:'—'}</b></div>
      ${prono.top_scorer?`<div style="font-size:12px;color:var(--gray);margin-top:2px">⚽ Buteur : <b style="color:var(--white)">${prono.top_scorer}</b></div>`:''}
      ${(prono.finalists||[]).length?`<div style="font-size:12px;color:var(--gray);margin-top:2px">🥈 Finaliste : <b style="color:var(--white)">${(prono.finalists||[]).map(id=>ALL_TEAMS.find(t=>t.id===id)?.name||id).join(', ')}</b></div>`:''}
    </div>`;
  });
  document.getElementById('league-pronos-panel').innerHTML=pronosHtml||`<div class="empty-state"><div class="empty-icon">🎯</div><div class="empty-title">Aucun prono</div><div class="empty-sub">Les joueurs n'ont pas encore soumis leur pronostic.</div></div>`;

  document.getElementById('league-details-panel').innerHTML=`<div style="padding:0 18px">
    <div style="background:var(--card);border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px;margin-bottom:12px">
      <div style="display:flex;flex-direction:column;gap:8px">
        <div style="display:flex;justify-content:space-between"><span style="color:var(--gray)">Code</span><b style="color:var(--gold);font-size:18px">${league.code}</b></div>
        <div style="display:flex;justify-content:space-between"><span style="color:var(--gray)">Joueurs</span><span>${league.players.length}</span></div>
        <div style="display:flex;justify-content:space-between"><span style="color:var(--gray)">Enjeu</span><span>${league.stake||'—'}</span></div>
      </div>
    </div>
    <button class="btn btn-gold" onclick="openShareModal()" style="margin-bottom:10px">📤 Partager le code</button>
    <button class="btn btn-outline" style="color:var(--red);border-color:rgba(255,68,68,.2)" onclick="leaveLeague('${league.id}')">Quitter la ligue</button>
  </div>`;
}

function renderProfil(){
  const name=currentProfile?.display_name||currentProfile?.username||'Joueur';
  document.getElementById('profil-scroll').innerHTML=`
    <div style="display:flex;flex-direction:column;align-items:center;padding:24px 18px 20px;text-align:center">
      <div style="width:76px;height:76px;border-radius:18px;background:linear-gradient(135deg,#1a1000,#0a0800);border:2px solid rgba(245,200,66,.3);display:flex;align-items:center;justify-content:center;font-weight:900;font-size:32px;color:var(--gold);margin-bottom:10px">${initials(name)}</div>
      <div style="font-weight:900;font-size:28px;text-transform:uppercase">${name}</div>
      <div style="font-size:12px;color:var(--gray);margin-top:3px">${myLeagues.length} ligue${myLeagues.length>1?'s':''} · WC 2026</div>
    </div>
    <div style="padding:0 18px;display:flex;flex-wrap:wrap;gap:7px;margin-bottom:20px">
      <div class="chip gold">🌍 FFL World Cup</div>
      ${myLeagues.length?'<div class="chip gold">🏆 Fondateur</div>':''}
    </div>
    <div class="btn-row"><button class="btn btn-outline" style="color:var(--red);border-color:rgba(255,68,68,.15)" onclick="signOut()">🚪 Se déconnecter</button></div>`;
}

function genCode(){const chars='ABCDEFGHJKLMNPQRSTUVWXYZ23456789';return 'WC-'+Array.from({length:3},()=>chars[Math.floor(Math.random()*chars.length)]).join('');}

async function createLeague(){
  const name=document.getElementById('cl-name').value.trim();
  const stake=document.getElementById('cl-stake').value.trim();
  if(!name){toast('⚠️ Entre un nom !');return;}
  const code=genCode();
  try{
    const rows=await dbInsert('wc_leagues',{name,code,stake:stake||null,created_by:currentUser.id});
    const league=Array.isArray(rows)?rows[0]:rows;
    await dbInsert('wc_members',{league_id:league.id,user_id:currentUser.id},false);
    if(myProno.winner||Object.keys(myProno.group_qualifiers||{}).length){
      await dbUpsert('wc_pronostics',{league_id:league.id,user_id:currentUser.id,group_qualifiers:myProno.group_qualifiers||{},quarterfinalists:myProno.quarterfinalists||[],semifinalists:myProno.semifinalists||[],finalists:myProno.finalists||[],winner:myProno.winner||'',top_scorer:myProno.top_scorer||''},'league_id,user_id');
    }
    toast('🎉 Ligue créée !');await loadMyData();currentLeagueId=league.id;
    document.getElementById('modal-code').textContent=code;
    document.getElementById('modal-link').textContent=`Rejoins ma FFL World Cup "${name}" ! Code : ${code}`;
    document.getElementById('modal-invite').classList.add('open');
    document.getElementById('cl-name').value='';document.getElementById('cl-stake').value='';
  }catch(e){toast('❌ Erreur : '+e.message);}
}

async function joinLeague(){
  const code=document.getElementById('join-code').value.trim().toUpperCase();
  if(!code||code.length<3){toast('⚠️ Entre un code valide !');return;}
  try{
    const leagues=await dbSelect('wc_leagues','code=eq.'+code+'&select=*');
    if(!leagues||!leagues.length){toast('❌ Code introuvable !');return;}
    const league=leagues[0];
    const existing=await dbSelect('wc_members','league_id=eq.'+league.id+'&user_id=eq.'+currentUser.id);
    if(existing&&existing.length){toast('Tu es déjà dans cette ligue !');return;}
    await dbInsert('wc_members',{league_id:league.id,user_id:currentUser.id},false);
    if(myProno.winner||Object.keys(myProno.group_qualifiers||{}).length){
      await dbUpsert('wc_pronostics',{league_id:league.id,user_id:currentUser.id,group_qualifiers:myProno.group_qualifiers||{},quarterfinalists:myProno.quarterfinalists||[],semifinalists:myProno.semifinalists||[],finalists:myProno.finalists||[],winner:myProno.winner||'',top_scorer:myProno.top_scorer||''},'league_id,user_id');
    }
    toast(`✅ Ligue "${league.name}" rejointe !`);await loadMyData();nav('s-home');document.getElementById('join-code').value='';
  }catch(e){toast('❌ Erreur : '+e.message);}
}

async function leaveLeague(id){
  if(!confirm('Quitter cette ligue ?'))return;
  await dbDelete('wc_members','league_id=eq.'+id+'&user_id=eq.'+currentUser.id);
  await dbDelete('wc_pronostics','league_id=eq.'+id+'&user_id=eq.'+currentUser.id);
  toast('👋 Ligue quittée');await loadMyData();nav('s-home');
}

function openShareModal(){
  const league=myLeagues.find(l=>l.id===currentLeagueId)||myLeagues[0];
  if(!league){toast("Crée d'abord une ligue !");return;}
  document.getElementById('modal-code').textContent=league.code;
  document.getElementById('modal-link').textContent=`Rejoins ma FFL World Cup "${league.name}" ! Code : ${league.code}`;
  document.getElementById('modal-invite').classList.add('open');
}

function copyInvite(){
  const league=myLeagues.find(l=>l.id===currentLeagueId)||myLeagues[0];
  const txt=league?`Rejoins ma FFL World Cup "${league.name}" !\n🔑 Code : ${league.code}`:'';
  navigator.clipboard?.writeText(txt).then(()=>toast('📋 Copié !')).catch(()=>toast('Code : '+(league?.code||'—')));
}

function closeModal(id){document.getElementById(id).classList.remove('open');}

function toast(msg,duration=2500){
  const t=document.getElementById('toast');t.textContent=msg;t.classList.add('show');
  clearTimeout(t._timer);t._timer=setTimeout(()=>t.classList.remove('show'),duration);
}

setTimeout(()=>{const s=document.getElementById('splash');if(s){s.style.display='none';if(s.parentNode)s.parentNode.removeChild(s);}},2800);

(async()=>{
  const session=getSession();
  if(session?.access_token&&session?.user){
    try{
      const res=await fetch(SUPABASE_URL+'/auth/v1/user',{headers:{'apikey':SUPABASE_KEY,'Authorization':'Bearer '+session.access_token}});
      if(res.ok){
        const user=await res.json();currentUser=user;
        currentProfile={id:user.id,username:user.user_metadata?.username||user.email?.split('@')[0],display_name:user.user_metadata?.display_name||user.user_metadata?.username||user.email?.split('@')[0]};
        await loadProfile();await loadMyData();goHome();
      }else{clearSession();goAuth();}
    }catch(e){goAuth();}
  }else{goAuth();}
})();

(function(){
  const btn=document.getElementById('auth-btn');if(btn)btn.onclick=authSubmit;
  const email=document.getElementById('auth-email');const pass=document.getElementById('auth-password');
  if(email)email.onkeydown=e=>{if(e.key==='Enter')authSubmit();};
  if(pass)pass.onkeydown=e=>{if(e.key==='Enter')authSubmit();};
})();
</script>
