async function loadMyData(){
  const ps=localStorage.getItem('ffl_wc_prono_'+currentUser.id);
  if(ps){try{myProno=JSON.parse(ps);}catch(e){}}
  try{
    const memberships=await dbSelect('wc_members','user_id=eq.'+currentUser.id+'&select=league_id');
    if(!memberships||!memberships.length){myLeagues=[];return;}
    const ids=memberships.map(m=>m.league_id);
    const leagues=await dbSelect('wc_leagues','id=in.('+ids.join(',')+')'+'&select=*');
    if(!leagues||!leagues.length){myLeagues=[];return;}
    myLeagues=await Promise.all(leagues.map(async(league)=>{
      const[members,pronos]=await Promise.all([
        dbSelect('wc_members','league_id=eq.'+league.id+'&select=user_id'),
        dbSelect('wc_pronostics','league_id=eq.'+league.id+'&select=user_id,winner,semifinalists,finalists,quarterfinalists,top_scorer,group_qualifiers')
      ]);
      const pids=(members||[]).map(m=>m.user_id);
      const profiles=pids.length?await dbSelect('profiles','id=in.('+pids.join(',')+')'+'&select=id,display_name,username'):[];
      const players=(members||[]).map(m=>{
        const profile=profiles.find(p=>p.id===m.user_id);
        const prono=pronos?.find(p=>p.user_id===m.user_id);
        return{id:m.user_id,name:profile?.display_name||profile?.username||'Joueur',prono:prono||null,isMe:m.user_id===currentUser.id};
      });
      return{...league,players};
    }));
  }catch(e){console.log('loadMyData:',e);myLeagues=[];}
}

function calcWCScore(prono){
  if(!prono)return 0;
  let total=0;
  Object.entries(WC_RESULTS.group_qualifiers).forEach(([grp,realQuals])=>{
    const myQ=prono.group_qualifiers?.[grp]||[];
    myQ.forEach(id=>{if(realQuals.includes(id))total+=POINTS.group_qualifier;});
  });
  (prono.quarterfinalists||[]).forEach(id=>{if(WC_RESULTS.quarterfinalists.includes(id))total+=POINTS.quarterfinalist;});
  (prono.semifinalists||[]).forEach(id=>{if(WC_RESULTS.semifinalists.includes(id))total+=POINTS.semifinalist;});
  (prono.finalists||[]).forEach(id=>{if(WC_RESULTS.finalists.includes(id))total+=POINTS.finalist;});
  if(prono.winner&&prono.winner===WC_RESULTS.winner)total+=POINTS.winner;
  if(prono.top_scorer&&prono.top_scorer.toLowerCase()===WC_RESULTS.top_scorer.toLowerCase())total+=POINTS.top_scorer;
  return total;
}

